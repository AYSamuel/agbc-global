# Normalize line endings to LF in the repo regardless of contributor OS.
* text=auto eol=lf

# Binaries: never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.hbc binary
*.jks binary
*.keystore binary
*.p8 binary
*.p12 binary
*.pdf binary
