{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "minimumReleaseAge": "7 days",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"]
  },
  "vulnerabilityAlerts": {
    "minimumReleaseAge": null,
    "labels": ["security"]
  },
  "packageRules": [
    {
      "description": "Expo SDK packages move together; group them so partial bumps never break the SDK pairing",
      "matchPackageNames": [
        "expo",
        "expo-*",
        "jest-expo",
        "eslint-config-expo",
        "@expo/*"
      ],
      "groupName": "expo sdk"
    }
  ]
}
