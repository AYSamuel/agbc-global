{
  "name": "agbc-global",
  "private": true,
  "packageManager": "pnpm@11.15.0",
  "engines": {
    "node": "\u003e=24.14.0"
  },
  "devDependencies": {
    "prettier": "^3.9.5"
  },
  "scripts": {
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:db": "supabase test db",
    "db:reset": "supabase db reset && node scripts/sync-local-sermons.mjs",
    "db:sync-sermons": "node scripts/sync-local-sermons.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck"
  }
}
