# Local dev values come from `supabase status` (URL + publishable key on the 553xx ports).
# Dev/prod values come from the Supabase dashboard. Real values live ONLY in untracked
# .env files locally and in EAS env vars for builds (docs/spec/23 §2). Never commit secrets.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_replace_me
