{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/mockup-reminder.cjs\"",
            "timeout": 10,
            "statusMessage": "Checking mockup coverage…"
          }
        ]
      }
    ]
  }
}
